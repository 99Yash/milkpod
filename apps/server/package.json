{
  "name": "server",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node --env-file=.env dist/index.js",
    "deploy": "pnpm --filter @milkpod/db db:migrate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.1004.0",
    "elysia": "catalog:",
    "@elysiajs/cors": "catalog:",
    "@elysiajs/node": "catalog:",
    "@milkpod/api": "workspace:*",
    "@milkpod/env": "workspace:*"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "tsx": "^4.19.2",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "@milkpod/config": "workspace:*"
  }
}
