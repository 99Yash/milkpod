# Database
DATABASE_URL="postgresql://user:password@localhost:5432/your_database_name"

# Better-Auth
BETTER_AUTH_SECRET="your-secret-key-here-min-32-chars-long!!"
BETTER_AUTH_URL="http://localhost:3001"

# CORS (Frontend URL)
CORS_ORIGIN="http://localhost:3000"

# Node Environment
NODE_ENV="development"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ElevenLabs (Transcription)
ELEVENLABS_API_KEY="your-elevenlabs-api-key"

# Upload storage (S3-compatible, used for manual upload durability)
UPLOAD_STORAGE_BUCKET="milkpod-uploads"
UPLOAD_STORAGE_REGION="auto"
# Optional endpoint for S3-compatible providers (Cloudflare R2, MinIO, etc.)
# UPLOAD_STORAGE_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
UPLOAD_STORAGE_ACCESS_KEY_ID="your-storage-access-key"
UPLOAD_STORAGE_SECRET_ACCESS_KEY="your-storage-secret-key"
# Set true for providers that require path-style requests
UPLOAD_STORAGE_FORCE_PATH_STYLE="false"
# Signed GET URL lifetime in seconds (used for ElevenLabs + visual extraction fetches)
UPLOAD_STORAGE_SIGNED_URL_TTL_SECONDS="900"

# AI providers (used by @milkpod/ai SDK providers)
OPENAI_API_KEY="your-openai-api-key"
GOOGLE_GENERATIVE_AI_API_KEY="your-google-generative-ai-api-key"

# Resend (Email OTP delivery)
RESEND_API_KEY="your-resend-api-key"

# Admin configuration (comma-separated emails that bypass daily word quota)
ADMIN_EMAILS=""

# Cookie domain (set in production when frontend + backend share a root domain, e.g. ".croisillies.xyz")
# COOKIE_DOMAIN=".croisillies.xyz"

# Billing provider — set to 'polar' to enable billing routes (omit to disable)
# BILLING_PROVIDER="polar"
# POLAR_ACCESS_TOKEN="your-polar-access-token"
# POLAR_WEBHOOK_SECRET="whsec_your-polar-webhook-secret"
# Comma-separated Polar product UUIDs per plan (monthly,yearly)
# POLAR_PRODUCT_PRO="uuid-monthly,uuid-yearly"
# POLAR_PRODUCT_TEAM="uuid-monthly,uuid-yearly"
