# Server URL
NEXT_PUBLIC_SERVER_URL="http://localhost:3001"

# Better-Auth
BETTER_AUTH_SECRET="your-secret-key-here-min-32-chars"
BETTER_AUTH_URL="http://localhost:3001"

# Database (for Better-Auth)
DATABASE_URL="postgresql://user:password@localhost:5432/your_database_name"

# Cookie domain (required in production; optional in development/test)
COOKIE_DOMAIN=".croisillies.xyz"

# Upload storage, ASSEMBLYAI_API_KEY, and AUTH_FROM_EMAIL are server-only and belong in apps/server/.env.
